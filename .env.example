# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Session
SESSION_SECRET=your-session-secret

# Server
PORT=5000

# Polar (Payments)
POLAR_ACCESS_TOKEN=your-polar-access-token

# Client-side (prefixed with VITE_)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_POLAR_REMOVE_ROW_PRODUCT_ID=your-product-id
VITE_POLAR_PREMIUM_PRODUCT_ID=your-product-id
